PORT=3001

# Database configuration
CRAWLER_DB_DRIVER=postgres
CRAWLER_DB_HOST=localhost
CRAWLER_DB_PORT=5432
CRAWLER_DB_USERNAME=your_db_user
CRAWLER_DB_PASSWORD=your_db_password
CRAWLER_DB_NAME=your_db_name

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Page crawl dispatch delay (ms between each CrawlDocumentPageJob dispatch). Default: 500.
# PAGE_CRAWL_DISPATCH_DELAY_MS=500

# Scheduled crawling
# Interval in milliseconds between automatic crawl runs (e.g. 86400000 = 24 h).
# If not set or invalid, scheduled crawling is disabled.
# CRAWL_SCHEDULE_MS=86400000

# Scheduled page crawling
# Interval in milliseconds between automatic page crawl runs.
# If not set or invalid, scheduled page crawling is disabled.
# PAGE_CRAWL_SCHEDULE_MS=86400000
