{
    "name": "devsearch-crawler",
    "version": "1.0.0",
    "description": "Crawls through Official Docs",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
        "test": "jest",
        "migration:run": "ts-node --transpile-only -e \"require('dotenv').config(); require('reflect-metadata'); const { default: ds } = require('./src/config/dataSource'); ds.initialize().then(() => ds.runMigrations()).then(() => { console.log('Migrations complete'); process.exit(0); }).catch(e => { console.error(e); process.exit(1); })\"",
        "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/dataSource.ts"
    },
    "keywords": [
        "devsearch"
    ],
    "author": "Subham Chakraborty",
    "license": "MIT",
    "dependencies": {
        "bullmq": "^5.69.4",
        "cheerio": "^1.2.0",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "ioredis": "5.9.2",
        "pg": "^8.18.0",
        "reflect-metadata": "^0.2.2",
        "typeorm": "^0.3.28"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.3.0",
        "@types/pg": "^8.16.0",
        "jest": "^30.2.0",
        "nodemon": "^3.1.13",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
