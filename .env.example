# Postgres (required — used by the postgres service and DATABASE_URL)
POSTGRES_USER=devsearch
POSTGRES_PASSWORD=devsearch
POSTGRES_DB=devsearch
POSTGRES_PORT=5433

# Redis
REDIS_PORT=6380

# API (DATABASE_URL and REDIS_URL required; PORT optional, defaults to 3000)
# Note: DATABASE_URL uses the Docker service name 'postgres', not POSTGRES_PORT
DATABASE_URL=postgresql://devsearch:devsearch@postgres:5432/devsearch
REDIS_URL=redis://redis:6379
PORT=3000

# Web (required — browser must be able to reach the api)
NEXT_PUBLIC_API_URL=http://localhost:3000
